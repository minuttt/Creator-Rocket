YOUTUBE_API_KEY=your_youtube_data_api_key
YOUTUBE_OAUTH_CLIENT_ID=your_google_oauth_client_id
YOUTUBE_OAUTH_CLIENT_SECRET=your_google_oauth_client_secret
YOUTUBE_OAUTH_REDIRECT_URI=http://localhost:8000/api/youtube/oauth/callback

# Optional legacy owner-token fallback. OAuth is preferred.
YOUTUBE_ANALYTICS_ACCESS_TOKEN=
YOUTUBE_ANALYTICS_CHANNEL_ID=
